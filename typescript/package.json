{
  "name": "langchain-kubernetes",
  "version": "0.1.0",
  "description": "Kubernetes sandbox provider for the DeepAgents framework",
  "license": "MIT",
  "author": "LangChain",
  "keywords": [
    "langchain",
    "deepagents",
    "kubernetes",
    "sandbox",
    "agents"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.build.cjs.json",
    "test": "vitest run tests/unit",
    "test:integration": "K8S_INTEGRATION=1 vitest run tests/integration",
    "test:all": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "deepagents": ">=0.1.0",
    "@kubernetes/client-node": "^1.0.0",
    "tar-stream": "^3.1.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/tar-stream": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/langchain-ai/langchain-kubernetes"
  }
}
